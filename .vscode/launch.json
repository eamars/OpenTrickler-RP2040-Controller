{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "RP2040 Debug, Load",
        "cwd": "${workspaceFolder}",
        "executable": "${command:cmake.launchTargetPath}",
        "request": "launch",
        "type": "cortex-debug",
        "servertype": "openocd",
        "gdbPath": "arm-none-eabi-gdb",
        "device": "RP2040",
        "configFiles": [
          "interface/cmsis-dap.cfg",
          "target/rp2040.cfg"
        ],
        "svdFile": "${workspaceFolder}/library/pico-sdk/src/rp2040/hardware_regs/RP2040.svd",
        "runToEntryPoint": "main",
        "openOCDLaunchCommands": [
          "adapter speed 5000"
        ],

        "postLaunchCommands": [
          "interrupt",
          "start",
          "load",
          "starti"
        ],
        "postRestartCommands": [
          "break main",
          "continue"
        ]
      },
